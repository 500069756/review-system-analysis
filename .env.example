# Anthropic Claude API key, exposed to the client bundle.
# Get one at https://console.anthropic.com/
#
# WARNING: VITE_* variables are bundled into the client JS and visible to
# anyone who loads the site. For production, proxy this call through a
# server-side endpoint and keep the key server-only.
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key
