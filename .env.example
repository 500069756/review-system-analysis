# OpenRouter API key, exposed to the client bundle.
# Get one at https://openrouter.ai/keys
#
# WARNING: VITE_* variables are bundled into the client JS and visible to
# anyone who loads the site. For production, proxy this call through a
# server-side endpoint (e.g. a Vercel Function) and keep the key server-only.
#
# Local dev:   copy this file to `.env` and fill in the value.
# Vercel:      add VITE_OPENROUTER_API_KEY in Project Settings → Environment Variables.
VITE_OPENROUTER_API_KEY=sk-or-v1-your-key-here
